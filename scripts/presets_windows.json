            }
        },
        {
            "name": "base_release",
            "generator": "Ninja",
            "binaryDir": "cmake_build",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_LINKER_TYPE": "LLD",
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "clang_18_release",
